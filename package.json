{
  "name": "mercy-ts-boilerplate-pro",
  "version": "2.3.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"node esbuild.config.mjs --watch\" \"npm run dev:ui\"",
    "build": "npm run build:ts && npm run build:ui && npm run generate-manifest",
    "build:ts": "node esbuild.config.mjs",
    "build:ui": "vite build",
    "dev:ui": "vite",
    "lint": "eslint src --fix",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,tsx,js}\"",
    "prepare": "husky",
    "generate-manifest": "node generate-manifest.js"
  },
  "devDependencies": {
    "@citizenfx/client": "^2.0.5012-1",
    "@citizenfx/server": "^2.0.5012-1",
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10.4",
    "concurrently": "^9",
    "dotenv": "^16",
    "esbuild": "^0.25",
    "eslint": "^9",
    "husky": "^9",
    "pino": "^9",
    "pino-pretty": "^13",
    "postcss": "^8",
    "prettier": "^3",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^3.4",
    "typescript": "^5.7",
    "vite": "^6",
    "vitest": "^3",
    "zod": "^3.24"
  }
}